.card.mb-3
  .list-group.list-group-flush
    = link_to Page::DOMESTIC, domestic_path, class: ['list-group-item list-group-item-action', ('active' if params[:action] == 'index')]
    = link_to Page::DOMESTIC_FIXTURES, domestic_fixtures_path, class: ['list-group-item list-group-item-action', ('active' if params[:action] == 'fixtures')]
    = link_to Page::DOMESTIC_UNIFORMS, uniforms_path, class: ['list-group-item list-group-item-action', ('active' if params[:action] == 'uniforms')]
    = link_to Page::DOMESTIC_FAQ, domestic_faq_path, class: ['list-group-item list-group-item-action', ('active' if params[:action] == 'faq')]
.d-flex.justify-content-center.mt-4
  = link_to "Join Us", members_path, class: 'btn btn-lg btn-primary'
